# ReadEasily — environment variables
#
# Copy this file to `.env.local` for local development:
#     cp .env.example .env.local
#
# `.env.local` is gitignored and MUST NEVER be committed. Real secrets live only
# in your machine's `.env.local` and in the hosting provider's secret store
# (Vercel → Project → Settings → Environment Variables). Anything prefixed with
# NEXT_PUBLIC_ is shipped to the browser — never put a secret there.

# ── Public (safe to expose to the browser) ───────────────────────────────────

# Canonical absolute origin of the deployed site. Used by SEO/metadata, the
# sitemap, robots.txt, OpenGraph image URLs and JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://readeasily.app

# Supabase project URL (optional, forward-looking). When set, next/image is
# allowed to optimize cover images served from Supabase Storage.
# NEXT_PUBLIC_SUPABASE_URL=

# Demo mode. Set to "enabled" to run the deployed app on MSW mock data (no real
# backend needed) — turns a Vercel deployment into a working, clickable demo.
# Leave unset for a real production build. Read at BUILD time, so set it in
# Vercel and redeploy for it to take effect.
# NEXT_PUBLIC_API_MOCKING=enabled

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ──────────────────────

# Google AI Studio (Gemini) key — powers on-the-fly practice-sentence
# generation. Free tier is enough for development. Get one at
# https://aistudio.google.com/apikey . If unset, the app falls back to
# zero-cost template sentences, so it stays fully functional without a key.
GEMINI_API_KEY=

# Gemini model id (optional). Defaults to gemini-2.5-flash in code.
# GEMINI_MODEL=gemini-2.5-flash

# ── Observability: Sentry (optional) ──────────────────────────────────────────
# Errors + Web Vitals. The SDK is a no-op until a DSN is provided, so the app
# and CI build run fine with these blank.

# Client + server DSN (this one is public by design — it only allows sending
# events, not reading them).
NEXT_PUBLIC_SENTRY_DSN=

# Used at BUILD time (in CI) to upload source maps for readable stack traces.
# Keep this secret — set it only as a CI / Vercel secret, never in the client.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
